# ──────────────────────────────────────────────────────────────
#  Muscle Mate - 環境変数サンプル
#  このファイルを backend/.env にコピーして実際のキーを設定してください
#  ⚠️ 実際のAPIキーをこのファイルに書かないでください（git管理対象）
# ──────────────────────────────────────────────────────────────

# Gemini API キー（Google AI Studio から取得）
GOOGLE_API_KEY=your_google_api_key_here

# バックエンドのベースURL（本番デプロイ時に設定）
API_BASE_URL=http://localhost:8000

# CORS許可オリジン（カンマ区切り。* は開発用のみ）
ALLOWED_ORIGINS=http://localhost:8089,http://localhost:3000

# Tavily / OpenAI（将来の拡張用。未使用の場合は空欄でOK）
TAVILY_API_KEY=your_tavily_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
